<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Rishabh Yadav — Product Manager</title>
<link href="https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500;700&family=Roboto:wght@300;400;500&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet"/>
<style>
:root{--blue:#1a0dab;--grey:#70757a;--border:#dfe1e5;--bg:#f8f9fa;--accent:#1a73e8;--green:#137333;--red:#c5221f;--amber:#b06000;}
*{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{font-family:'Roboto',sans-serif;background:#fff;color:#202124;font-size:14px;}

/* HEADER */
header{display:flex;align-items:center;gap:20px;padding:14px 24px 0;border-bottom:1px solid var(--border);position:sticky;top:0;background:#fff;z-index:100;flex-wrap:wrap;}
.logo{font-size:22px;font-weight:700;letter-spacing:-.5px;white-space:nowrap;cursor:pointer;font-family:'Google Sans',sans-serif;}
.logo span:nth-child(1){color:#4285F4;}.logo span:nth-child(2){color:#EA4335;}.logo span:nth-child(3){color:#FBBC05;}
.logo span:nth-child(4){color:#4285F4;}.logo span:nth-child(5){color:#34A853;}.logo span:nth-child(6){color:#EA4335;}.logo span:nth-child(7){color:#FBBC05;}
.sbar{display:flex;align-items:center;gap:12px;flex:1;max-width:692px;border:1px solid var(--border);border-radius:24px;padding:8px 16px;box-shadow:0 1px 6px rgba(32,33,36,.1);font-size:16px;}
.sbar .material-symbols-outlined{color:var(--grey);font-size:20px;}
.sbar-q{flex:1;font-size:16px;color:#202124;}
.h-right{display:flex;align-items:center;gap:8px;margin-left:auto;}
.av{width:32px;height:32px;border-radius:50%;overflow:hidden;cursor:pointer;}
.av img{width:100%;height:100%;object-fit:cover;object-position:center top;}

/* NAV */
nav{display:flex;padding:0 0 0 164px;margin-top:8px;overflow-x:auto;border-bottom:1px solid var(--border);}
nav a{display:flex;align-items:center;gap:6px;padding:12px 16px 10px;text-decoration:none;color:var(--grey);font-size:13px;white-space:nowrap;font-family:'Google Sans',sans-serif;border-bottom:3px solid transparent;transition:color .15s,border-color .15s;cursor:pointer;}
nav a:hover{color:#202124;}
nav a.active{color:var(--accent);border-bottom-color:var(--accent);}
nav a .material-symbols-outlined{font-size:17px;font-variation-settings:'FILL' 0,'wght' 300;}

/* LAYOUT */
.wrap{display:grid;grid-template-columns:1fr 332px;gap:40px;max-width:1180px;margin:0 auto;padding:24px 24px 60px 184px;}
@media(max-width:960px){.wrap{grid-template-columns:1fr;padding:16px;}.sb{display:none;}nav{padding-left:0;}}

/* PAGES */
.pg{display:none;animation:fu .25s ease both;}
.pg.on{display:block;}
@keyframes fu{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

/* RESULT META */
.rmeta{color:var(--grey);font-size:13px;margin-bottom:18px;}

/* FEATURED */
.feat{border-left:4px solid var(--accent);background:var(--bg);border-radius:0 8px 8px 0;padding:16px 20px;margin-bottom:26px;}
.feat-lbl{font-size:11px;color:var(--grey);text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px;}
.feat-title{font-size:16px;font-weight:500;margin-bottom:8px;color:#202124;font-family:'Google Sans',sans-serif;}
.feat-body{font-size:14px;color:#4d5156;line-height:1.65;}
.feat-body strong{color:#202124;}
.pills{display:flex;flex-wrap:wrap;gap:6px;margin-top:12px;}
.pill{border-radius:16px;padding:4px 12px;font-size:12px;font-weight:500;}
.pb{background:#e8f0fe;color:#1a73e8;}.pg2{background:#e6f4ea;color:#137333;}
.pa{background:#fef7e0;color:#b06000;}.pr{background:#fce8e6;color:#c5221f;}
.pp{background:#f3e8fd;color:#7c15c5;}

/* RESULT */
.res{margin-bottom:28px;}
.rurl{display:flex;align-items:center;gap:6px;margin-bottom:4px;}
.rfav{width:18px;height:18px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:9px;color:#fff;font-weight:700;flex-shrink:0;}
.rurltext{font-size:12px;color:var(--grey);}
.rtitle{font-size:20px;font-weight:400;color:var(--blue);cursor:pointer;font-family:'Google Sans',sans-serif;line-height:1.3;margin-bottom:6px;text-decoration:none;display:block;}
.rtitle:hover{text-decoration:underline;}
.rdesc{font-size:14px;color:#4d5156;line-height:1.58;max-width:650px;}
.rdesc strong{color:#202124;}

/* SITELINKS */
.sl{display:flex;flex-wrap:wrap;gap:8px;margin-top:10px;}
.sl a{border:1px solid var(--border);border-radius:8px;padding:10px 16px;text-decoration:none;color:var(--blue);font-size:13px;font-family:'Google Sans',sans-serif;transition:background .15s;cursor:pointer;display:block;}
.sl a:hover{background:var(--bg);}
.sl a small{display:block;color:var(--grey);font-size:11px;margin-top:2px;}

/* DIVIDER */
.div{border:none;border-top:1px solid var(--border);margin:8px 0 24px;}

/* PAA */
.paa{margin-bottom:28px;}
.paa-title{font-size:17px;font-family:'Google Sans',sans-serif;font-weight:400;margin-bottom:12px;}
.paa-item{border:1px solid var(--border);border-radius:8px;margin-bottom:4px;overflow:hidden;}
.paa-q{display:flex;justify-content:space-between;align-items:center;padding:14px 16px;cursor:pointer;font-size:14px;font-weight:500;background:#fff;transition:background .15s;}
.paa-q:hover{background:var(--bg);}
.paa-a{display:none;padding:12px 16px 16px;background:var(--bg);font-size:14px;color:#4d5156;line-height:1.65;border-top:1px solid var(--border);}
.paa-a strong{color:#202124;}
.paa-item.open .paa-a{display:block;}
.paa-item.open .paa-q .material-symbols-outlined{transform:rotate(180deg);}
.paa-q .material-symbols-outlined{transition:transform .2s;font-size:20px;color:var(--grey);}

/* PROJECT GRID */
.pgrid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:12px;}
@media(max-width:600px){.pgrid{grid-template-columns:1fr;}}
.pcard{border:1px solid var(--border);border-radius:12px;padding:16px;transition:box-shadow .2s,border-color .2s;cursor:pointer;}
.pcard:hover{box-shadow:0 2px 12px rgba(0,0,0,.1);border-color:#bbb;}
.pcard-ico{font-size:24px;margin-bottom:8px;}
.pcard-name{font-size:14px;font-weight:500;color:var(--blue);margin-bottom:3px;font-family:'Google Sans',sans-serif;}
.pcard-tech{font-size:11px;color:var(--grey);margin-bottom:5px;}
.pcard-desc{font-size:13px;color:#4d5156;line-height:1.5;}

/* DETAIL PAGES */
.back{display:inline-flex;align-items:center;gap:6px;color:var(--accent);font-size:13px;cursor:pointer;margin-bottom:20px;padding:6px 12px;border-radius:20px;border:1px solid var(--border);transition:background .15s;font-family:'Google Sans',sans-serif;}
.back:hover{background:var(--bg);}
.back .material-symbols-outlined{font-size:16px;}
.dhero{background:linear-gradient(135deg,#e8f0fe 0%,#f0f8e8 100%);border-radius:12px;padding:24px 28px;margin-bottom:28px;border:1px solid #d2e3fc;}
.dhero-title{font-size:24px;font-family:'Google Sans',sans-serif;font-weight:500;margin-bottom:6px;}
.dhero-sub{color:var(--grey);font-size:14px;margin-bottom:14px;}
.dsec{margin-bottom:32px;}
.dsec-title{font-size:16px;font-weight:500;font-family:'Google Sans',sans-serif;border-bottom:2px solid #e8f0fe;padding-bottom:8px;margin-bottom:18px;color:#202124;}

/* CASE STUDY CARD */
.csc{border:1px solid var(--border);border-radius:12px;padding:22px;margin-bottom:16px;transition:box-shadow .15s;}
.csc:hover{box-shadow:0 2px 10px rgba(0,0,0,.08);}
.csc-hd{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px;flex-wrap:wrap;gap:8px;}
.csc-co{font-size:15px;font-weight:600;color:#202124;}
.csc-role{font-size:13px;color:var(--accent);font-weight:500;margin-bottom:3px;}
.csc-pd{font-size:12px;color:var(--grey);white-space:nowrap;}
.igrid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:14px 0;}
@media(max-width:600px){.igrid{grid-template-columns:1fr;}}
.ib{border-radius:8px;padding:14px;}
.ib.wrong{background:rgba(197,34,31,.04);border:1px solid rgba(197,34,31,.2);}
.ib.right{background:rgba(19,115,51,.04);border:1px solid rgba(19,115,51,.2);}
.ib.dec{background:rgba(26,115,232,.04);border:1px solid rgba(26,115,232,.2);}
.ib.out{background:rgba(176,96,0,.04);border:1px solid rgba(176,96,0,.2);}
.ib-lbl{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;margin-bottom:6px;}
.ib.wrong .ib-lbl{color:var(--red);}.ib.right .ib-lbl{color:var(--green);}
.ib.dec .ib-lbl{color:var(--accent);}.ib.out .ib-lbl{color:var(--amber);}
.ib-txt{font-size:13px;color:#4d5156;line-height:1.55;}
.ib-txt strong{color:#202124;}
.pull{border-left:3px solid var(--accent);padding:12px 18px;margin:14px 0;background:rgba(26,115,232,.04);border-radius:0 6px 6px 0;font-size:14px;color:#202124;line-height:1.6;font-style:italic;}
.cbul{padding-left:18px;margin:10px 0;}
.cbul li{font-size:14px;color:#4d5156;line-height:1.7;margin-bottom:5px;}
.cbul li strong{color:#202124;}
.ctags{display:flex;flex-wrap:wrap;gap:6px;margin-top:12px;}
.ctag{background:#f1f3f4;color:#3c4043;border-radius:12px;padding:3px 10px;font-size:11px;font-weight:500;}
.mets{display:flex;flex-wrap:wrap;gap:10px;margin-top:14px;}
.met{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:10px 16px;text-align:center;}
.met-v{font-size:18px;font-weight:500;color:var(--accent);font-family:'Google Sans',sans-serif;display:block;}
.met-l{font-size:11px;color:var(--grey);display:block;margin-top:2px;}

/* TIMELINE */
.tl{margin-top:12px;}
.tl-it{display:flex;gap:14px;margin-bottom:16px;}
.tl-dc{display:flex;flex-direction:column;align-items:center;padding-top:2px;}
.tl-d{width:10px;height:10px;border-radius:50%;background:var(--accent);flex-shrink:0;}
.tl-ln{flex:1;width:2px;background:var(--border);margin-top:4px;}
.tl-co{flex:1;}
.tl-co-name{font-weight:500;font-size:14px;color:#202124;}
.tl-co-meta{color:var(--grey);font-size:12px;margin:2px 0 4px;}
.tl-co-desc{font-size:13px;color:#4d5156;line-height:1.5;}

/* EDU */
.ecard{border:1px solid var(--border);border-radius:12px;padding:20px;margin-bottom:14px;display:flex;gap:16px;align-items:flex-start;}
.eico{width:48px;height:48px;border-radius:10px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:22px;background:#e8f0fe;}
.ebody .einst{font-size:15px;font-weight:600;color:#202124;}
.ebody .edeg{font-size:13px;color:var(--accent);margin:2px 0 4px;}
.ebody .eper{font-size:12px;color:var(--grey);}
.ebody .edet{font-size:13px;color:#4d5156;margin-top:8px;line-height:1.6;}
.ebody .edet strong{color:#202124;}

/* SKILLS */
.skgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:12px;}
.skgrp{border:1px solid var(--border);border-radius:10px;padding:14px;}
.skgrp-t{font-size:11px;font-weight:600;color:var(--grey);text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px;}
.ski{font-size:13px;color:#202124;padding:3px 0;display:flex;align-items:center;gap:6px;}
.skd{width:6px;height:6px;border-radius:50%;background:var(--accent);flex-shrink:0;}

/* OPINIONS */
.opi-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:28px;}
@media(max-width:600px){.opi-grid{grid-template-columns:1fr;}}
.opi-card{border:1px solid var(--border);border-radius:10px;padding:16px;transition:border-color .2s;}
.opi-card:hover{border-color:#bbb;}
.opi-num{font-size:11px;color:var(--grey);font-weight:500;margin-bottom:8px;letter-spacing:.04em;}
.opi-text{font-size:14px;color:#202124;line-height:1.55;font-weight:400;margin-bottom:6px;}
.opi-sub{font-size:12px;color:var(--grey);line-height:1.5;}

/* CONTACT */
.cgrid{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
@media(max-width:600px){.cgrid{grid-template-columns:1fr;}}
.ccard{border:1px solid var(--border);border-radius:12px;padding:18px;display:flex;align-items:center;gap:14px;text-decoration:none;color:inherit;transition:box-shadow .15s,border-color .15s;}
.ccard:hover{box-shadow:0 2px 10px rgba(0,0,0,.1);border-color:#bbb;}
.cico{width:40px;height:40px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
.clbl{font-size:11px;color:var(--grey);letter-spacing:.04em;}
.cval{font-size:14px;font-weight:500;color:var(--accent);}

/* CHAT */
.chatwin{background:#fff;border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-top:16px;}
.chatmsgs{height:360px;overflow-y:auto;padding:20px;display:flex;flex-direction:column;gap:14px;}
.chatmsgs::-webkit-scrollbar{width:4px;}
.chatmsgs::-webkit-scrollbar-thumb{background:var(--border);border-radius:4px;}
.msg{max-width:88%;animation:fu .2s ease;}
.msg-b{align-self:flex-start;}.msg-u{align-self:flex-end;}
.mbub{padding:11px 15px;border-radius:16px;font-size:14px;line-height:1.58;}
.msg-b .mbub{background:var(--bg);color:#202124;border:1px solid var(--border);border-radius:4px 16px 16px 16px;}
.msg-u .mbub{background:var(--accent);color:#fff;border-radius:16px 4px 16px 16px;}
.mname{font-size:11px;color:var(--grey);margin-bottom:4px;font-weight:500;letter-spacing:.04em;}
.msg-u .mname{text-align:right;}
.typing{display:flex;gap:4px;padding:12px 15px;}
.typing span{width:6px;height:6px;border-radius:50%;background:var(--grey);animation:b 1.2s infinite;}
.typing span:nth-child(2){animation-delay:.2s;}.typing span:nth-child(3){animation-delay:.4s;}
@keyframes b{0%,60%,100%{transform:translateY(0);opacity:.4}30%{transform:translateY(-4px);opacity:1}}
.starters{display:flex;gap:8px;flex-wrap:wrap;padding:12px 20px 0;border-top:1px solid var(--border);}
.st{font-size:12px;background:var(--bg);color:var(--grey);border:1px solid var(--border);border-radius:20px;padding:6px 13px;cursor:pointer;transition:all .2s;font-family:'Roboto',sans-serif;}
.st:hover{border-color:var(--accent);color:var(--accent);background:#e8f0fe;}
.chatform{display:flex;gap:10px;padding:14px 20px;border-top:1px solid var(--border);align-items:center;}
.cinput{flex:1;background:var(--bg);border:1px solid var(--border);border-radius:24px;padding:10px 18px;font-family:'Roboto',sans-serif;font-size:14px;color:#202124;outline:none;transition:border-color .2s;}
.cinput::placeholder{color:var(--grey);}
.cinput:focus{border-color:var(--accent);}
.csend{background:var(--accent);color:#fff;border:none;border-radius:24px;padding:10px 20px;font-family:'Google Sans',sans-serif;font-size:13px;font-weight:500;cursor:pointer;transition:opacity .2s;white-space:nowrap;}
.csend:hover{opacity:.85;}.csend:disabled{opacity:.5;cursor:default;}

/* SIDEBAR */
.sb{font-size:13px;}
.kp{border:1px solid var(--border);border-radius:12px;padding:20px;margin-bottom:14px;}
.kp-av{width:100%;aspect-ratio:4/5;border-radius:10px;margin-bottom:16px;overflow:hidden;background:linear-gradient(135deg,#1a73e8,#34A853);}
.kp-av img{width:100%;height:100%;object-fit:cover;object-position:center top;display:block;border-radius:10px;}
.kp-name{font-size:21px;font-family:'Google Sans',sans-serif;font-weight:400;margin-bottom:3px;}
.kp-role{font-size:13px;color:var(--grey);margin-bottom:6px;}
.kp-tag{display:inline-block;font-size:11px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--amber);background:#fef7e0;border:1px solid rgba(176,96,0,.2);border-radius:20px;padding:4px 10px;margin-bottom:12px;}
.kp-desc{color:#4d5156;line-height:1.6;margin-bottom:14px;font-size:13px;}
.kp-row{display:flex;gap:8px;padding:8px 0;border-bottom:1px solid var(--border);font-size:13px;}
.kp-row:last-of-type{border-bottom:none;}
.kp-lbl{color:var(--grey);width:72px;flex-shrink:0;}
.kp-val{color:#202124;}
.kp-stats{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin:14px 0;}
.kp-st{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:10px;text-align:center;}
.kp-stv{font-size:17px;font-weight:500;color:var(--accent);display:block;font-family:'Google Sans',sans-serif;}
.kp-stl{font-size:10px;color:var(--grey);display:block;margin-top:2px;}
.kp-links{display:flex;gap:8px;flex-wrap:wrap;margin-top:14px;}
.kp-lk{display:flex;align-items:center;gap:5px;color:var(--accent);text-decoration:none;font-size:12px;padding:6px 12px;border:1px solid var(--border);border-radius:20px;transition:background .15s;}
.kp-lk:hover{background:var(--bg);}
.kp-lk .material-symbols-outlined{font-size:14px;}
.rbtn{display:flex;align-items:center;justify-content:center;gap:6px;width:100%;padding:9px;border-radius:20px;background:var(--accent);color:#fff;text-decoration:none;font-size:13px;font-weight:500;font-family:'Google Sans',sans-serif;margin-top:12px;transition:opacity .2s;}
.rbtn:hover{opacity:.85;}
.licard{border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:14px;}
.libanner{height:64px;background:linear-gradient(120deg,#0a66c2,#0d8fde);position:relative;}
.lilogo{position:absolute;bottom:-20px;left:16px;width:48px;height:48px;border-radius:8px;background:#fff;border:2px solid #fff;overflow:hidden;box-shadow:0 2px 6px rgba(0,0,0,.15);}
.lilogo img{width:100%;height:100%;object-fit:cover;object-position:center top;border-radius:6px;}
.libody{padding:28px 16px 16px;}
.liname{font-size:14px;font-weight:600;color:#202124;}
.lihl{font-size:12px;color:#4d5156;margin:2px 0 8px;line-height:1.4;}
.limeta{display:flex;gap:10px;font-size:11px;color:var(--grey);margin-bottom:12px;flex-wrap:wrap;}
.limeta span{display:flex;align-items:center;gap:3px;}
.limeta .material-symbols-outlined{font-size:12px;}
.libtn{display:flex;align-items:center;justify-content:center;gap:6px;width:100%;padding:7px;border-radius:20px;border:1.5px solid #0a66c2;color:#0a66c2;font-size:13px;font-weight:600;text-decoration:none;font-family:'Google Sans',sans-serif;transition:background .15s;}
.libtn:hover{background:#e8f0fe;}
.libtn svg{width:14px;height:14px;flex-shrink:0;}
.lidiv{border:none;border-top:1px solid var(--border);margin:10px 0;}
.lisr{display:flex;}
.lis{flex:1;text-align:center;padding:6px 4px;}
.lis .n{font-size:14px;font-weight:600;color:#0a66c2;}
.lis .l{font-size:10px;color:var(--grey);margin-top:1px;}
.relcard{border:1px solid var(--border);border-radius:12px;padding:16px;margin-bottom:14px;}
.reli{display:flex;align-items:center;gap:8px;padding:7px 0;cursor:pointer;color:var(--blue);font-size:13px;border-bottom:1px solid var(--border);}
.reli:last-child{border-bottom:none;}
.reli:hover{text-decoration:underline;}
.reli .material-symbols-outlined{font-size:15px;color:var(--grey);}
footer{background:var(--bg);border-top:1px solid var(--border);padding:12px 24px;color:var(--grey);font-size:13px;display:flex;gap:24px;flex-wrap:wrap;margin-top:32px;}
footer a{color:var(--grey);text-decoration:none;}
footer a:hover{text-decoration:underline;color:var(--blue);}
</style>
</head>
<body>

<header>
  <div class="logo" onclick="show('home')">
    <span>R</span><span>i</span><span>s</span><span>h</span><span>a</span><span>b</span><span>h</span>
  </div>
  <div class="sbar">
    <span class="material-symbols-outlined">search</span>
    <div class="sbar-q">Rishabh Yadav — Product Manager, IIT Kanpur, CARS24</div>
    <span class="material-symbols-outlined" style="color:#4285F4;cursor:pointer">search</span>
  </div>
  <div class="h-right">
    <span class="material-symbols-outlined" style="color:var(--grey);cursor:pointer;font-size:22px">apps</span>
    <div class="av"><img src="data:image/jpeg;base64," alt="RY"/></div>
  </div>
</header>

<nav>
  <a class="active" data-pg="home" onclick="show('home',this)"><span class="material-symbols-outlined">language</span>All</a>

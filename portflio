  hist.push({role:'user',content:m});
  showTyp();
  document.getElementById('csend').disabled=true;
  try{
    const r=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,system:SYS,messages:hist})
    });
    const d=await r.json();
    const rep=d.content?.[0]?.text||'Something went wrong. Please try again.';
    hideTyp();
    addMsg('b',rep);
    hist.push({role:'assistant',content:rep});
  }catch(e){hideTyp();addMsg('b','Connection error. Try again.');}
  document.getElementById('csend').disabled=false;
}

function star(btn){document.getElementById('cinput').value=btn.textContent;send();}

function addMsg(t,txt){
  const c=document.getElementById('chatmsgs');
  const d=document.createElement('div');
  d.className='msg msg-'+(t==='b'?'b':'u');
  d.innerHTML='<div class="mname">'+(t==='b'?'RISHABH · AI':'YOU')+'</div><div class="mbub">'+txt.replace(/\n/g,'<br/>')+'</div>';
  c.appendChild(d);c.scrollTop=c.scrollHeight;
}

let te=null;
function showTyp(){
  const c=document.getElementById('chatmsgs');
  te=document.createElement('div');
  te.className='msg msg-b';
  te.innerHTML='<div class="mname">RISHABH · AI</div><div class="mbub"><div class="typing"><span></span><span></span><span></span></div></div>';
  c.appendChild(te);c.scrollTop=c.scrollHeight;
}
function hideTyp(){if(te){te.remove();te=null;}}

function show(id,el){
  document.querySelectorAll('.pg').forEach(p=>p.classList.remove('on'));
  const t=document.getElementById('pg-'+id);
  if(t){t.classList.add('on');window.scrollTo({top:0,behavior:'smooth'});}
  document.querySelectorAll('nav a').forEach(a=>a.classList.toggle('active',a.dataset.pg===id));
}

function paa(el){el.classList.toggle('open');}

document.getElementById('cinput').addEventListener('keydown',e=>{if(e.key==='Enter')send();});
</script>
</body>
</html>
